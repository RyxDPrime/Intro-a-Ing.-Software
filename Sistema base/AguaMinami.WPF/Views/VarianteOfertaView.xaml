<UserControl x:Class="AguaMinami.WPF.Views.VarianteOfertaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" d:DesignHeight="550" d:DesignWidth="900"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── Card del formulario ─── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Variantes de oferta" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Catalogo de variantes elegibles para ofertas"
                           Style="{StaticResource SectionSubtitle}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Fila 1 -->
                    <TextBlock Text="Nombre" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"/>

                    <!-- Fila 2 -->
                    <TextBlock Text="Descripcion" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}"
                               VerticalAlignment="Top" Margin="0,6,10,0"/>
                    <TextBox Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="1" Grid.Column="1"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalContentAlignment="Top" Padding="10,8" Margin="0,0,0,16"/>

                    <!-- Botones -->
                    <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                HorizontalAlignment="Right">
                        <Button Content="Nuevo" Command="{Binding NewCommand}"
                                Width="100" Margin="0,0,8,0"/>
                        <Button Content="Guardar" Command="{Binding SaveCommand}"
                                Style="{StaticResource SuccessButton}" Width="110" Margin="0,0,8,0"/>
                        <Button Content="Eliminar" Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButton}" Width="110"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ─── Card de la tabla ─── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      BorderThickness="0">
                <DataGrid.InputBindings>
                    <MouseBinding Gesture="LeftDoubleClick"
                        Command="{Binding SelectCommand}"
                        CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdVariante}" Width="60"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Descripcion" Binding="{Binding Descripcion}" Width="320"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
