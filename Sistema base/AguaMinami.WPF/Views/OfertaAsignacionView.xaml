<UserControl x:Class="AguaMinami.WPF.Views.OfertaAsignacionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" d:DesignHeight="550" d:DesignWidth="900"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── Card del formulario ─── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Asignacion de ofertas" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Asigna ofertas a clientes o variantes de producto"
                           Style="{StaticResource SectionSubtitle}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Fila 1 -->
                    <TextBlock Text="Oferta" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <ComboBox ItemsSource="{Binding Ofertas}" SelectedValue="{Binding IdOferta}"
                              SelectedValuePath="IdOferta" DisplayMemberPath="Nombre"
                              Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"/>

                    <TextBlock Text="ID entidad" Grid.Row="0" Grid.Column="3" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding IdEntidad, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="0" Grid.Column="4" Margin="0,0,0,12"/>

                    <!-- Fila 2 -->
                    <TextBlock Text="ID variante" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding IdVariante, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"/>

                    <!-- Botones -->
                    <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5"
                                HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Content="Nuevo" Command="{Binding NewCommand}"
                                Width="100" Margin="0,0,8,0"/>
                        <Button Content="Guardar" Command="{Binding SaveCommand}"
                                Style="{StaticResource SuccessButton}" Width="110" Margin="0,0,8,0"/>
                        <Button Content="Eliminar" Command="{Binding DeleteCommand}"
                                Style="{StaticResource DangerButton}" Width="110"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ─── Card de la tabla ─── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                      IsReadOnly="True" SelectionMode="Single"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      BorderThickness="0">
                <DataGrid.InputBindings>
                    <MouseBinding Gesture="LeftDoubleClick"
                        Command="{Binding SelectCommand}"
                        CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding IdAsignacion}" Width="60"/>
                    <DataGridTextColumn Header="Oferta" Binding="{Binding NombreOferta}" Width="*"/>
                    <DataGridTextColumn Header="Entidad" Binding="{Binding IdEntidad}" Width="140"/>
                    <DataGridTextColumn Header="Variante" Binding="{Binding IdVariante}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
