<Window x:Class="AguaMinami.WPF.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AguaMinami.WPF.Views"
        Title="Agua Minami - Sistema de Gestion" Height="780" Width="1150"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Boton de caption (minimizar/maximizar) -->
        <Style x:Key="CaptionBtn" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#8EA3BD"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1A2D44"/>
                                <Setter Property="Foreground" Value="#C8D6E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#243B56"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Boton cerrar (rojo al hover) -->
        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#8EA3BD"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#B22A1C"/>
                                <Setter Property="Foreground" Value="#FFD0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab moderno -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Padding="{TemplateBinding Padding}"
                                Background="Transparent" BorderThickness="0,0,0,2"
                                BorderBrush="Transparent" Margin="0,0,4,0">
                            <ContentPresenter x:Name="contentPresenter"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryLightBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#D0D5DD"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder">
        <DockPanel>

            <!-- ══════════════════════════════════════════════════════════
                 BARRA DE TITULO PERSONALIZADA
                 ══════════════════════════════════════════════════════════ -->
            <Grid DockPanel.Dock="Top" Height="38" Background="#0B1929">
                <!-- Titulo izquierda -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <!-- Icono gota -->
                    <Border Width="22" Height="22" CornerRadius="5" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D47A1" Offset="0"/>
                                <GradientStop Color="#00ACC1" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                              Width="11" Height="11" Stretch="Uniform" Fill="White"
                              Data="M12,2 C12,2 4.5,12.5 4.5,17 C4.5,21.14 7.86,24.5 12,24.5 C16.14,24.5 19.5,21.14 19.5,17 C19.5,12.5 12,2 12,2 Z"/>
                    </Border>
                    <TextBlock Text="Agua Minami" Foreground="#7B93AD"
                               FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center"/>
                    <TextBlock Text="  —  Sistema de Gestion" Foreground="#3D5478"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Botones ventana derecha -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" Style="{StaticResource CaptionBtn}"
                            Click="Minimize_Click"/>
                    <Button x:Name="BtnMaxRestore" Content="&#xE922;" Style="{StaticResource CaptionBtn}"
                            Click="MaxRestore_Click"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CloseBtn}"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════
                 CONTENIDO
                 ══════════════════════════════════════════════════════════ -->
            <Grid>
                <!-- Vista Dashboard (visible por defecto) -->
                <views:DashboardView x:Name="DashboardPanel"/>

                <!-- Vista Ofertas (oculta por defecto) -->
                <DockPanel x:Name="OfertasPanel" Visibility="Collapsed">

                    <!-- Header profesional -->
                    <Border DockPanel.Dock="Top" Padding="24,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.3">
                                <GradientStop Color="#0D47A1" Offset="0"/>
                                <GradientStop Color="#1565C0" Offset="0.5"/>
                                <GradientStop Color="#1976D2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Boton Volver -->
                                <Button x:Name="BtnVolver" Click="BtnVolver_Click" Cursor="Hand"
                                        VerticalAlignment="Center" Margin="0,0,16,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnBorder" CornerRadius="8" Padding="10,8"
                                                    Background="#1E88E520" BorderThickness="1" BorderBrush="#FFFFFF30">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="M20,11 L7.83,11 L13.42,5.41 L12,4 L4,12 L12,20 L13.41,18.59 L7.83,13 L20,13 Z"
                                                          Fill="White" Width="16" Height="16" Stretch="Uniform"
                                                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Inicio" Foreground="White" FontSize="12"
                                                               VerticalAlignment="Center" FontWeight="Medium"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnBorder" Property="Background" Value="#1E88E550"/>
                                                    <Setter TargetName="btnBorder" Property="BorderBrush" Value="#FFFFFF60"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="btnBorder" Property="Background" Value="#1E88E580"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Titulo -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Agua Minami"
                                               Foreground="White" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Text="Modulo de Ofertas"
                                               Foreground="#B3D4FC" FontSize="12" FontWeight="Normal"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>


                    <!-- Tabs CRUD -->
                    <TabControl x:Name="MainTabs" Margin="0" Padding="0" BorderThickness="0" Background="Transparent"
                                SelectionChanged="MainTabs_SelectionChanged">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                            Padding="20,0">
                                        <TabPanel IsItemsHost="True" Margin="0,0,0,-1"/>
                                    </Border>
                                    <Border Background="{StaticResource BackgroundBrush}" Padding="20,16">
                                        <ContentPresenter ContentSource="SelectedContent"/>
                                    </Border>
                                </DockPanel>
                            </ControlTemplate>
                        </TabControl.Template>

                        <TabItem Header="Ofertas">
                            <views:OfertaView DataContext="{Binding Ofertas}"/>
                        </TabItem>

                        <TabItem Header="Oferta x Cantidad">
                            <views:OfertaCantidadView DataContext="{Binding OfertasCantidad}"/>
                        </TabItem>

                        <TabItem Header="Oferta x Descuento">
                            <views:OfertaDescuentoView DataContext="{Binding OfertasDescuento}"/>
                        </TabItem>

                        <TabItem Header="Asignaciones">
                            <views:OfertaAsignacionView DataContext="{Binding OfertasAsignacion}"/>
                        </TabItem>

                        <TabItem Header="Variantes">
                            <views:VarianteOfertaView DataContext="{Binding VariantesOferta}"/>
                        </TabItem>

                    </TabControl>
                </DockPanel>
            </Grid>

        </DockPanel>
    </Border>
</Window>
